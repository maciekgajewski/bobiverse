{
  "name": "bobiverse",
  "version": "1.0.0",
  "description": "Bobiverse is a planned spoiler-safe visual companion for the books by Dennis E. Taylor. Its central feature is a true-scale, interactive 3D map that helps readers understand the relative orientation and distances of nearby stellar systems. Later phases connect that map to chapters, characters, travel, events, and Bob genealogy.",
  "private": true,
  "type": "module",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "engines": {
    "node": "22.23.1",
    "npm": "10.9.8"
  },
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 5173 --strictPort",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\" \"tests/**/*.{ts,tsx}\" \"data/**/*.json\" \"*.{js,json,ts}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css,json}\" \"tests/**/*.{ts,tsx}\" \"data/**/*.json\" \"*.{js,json,ts}\"",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "data:refresh": "./.venv/bin/python scripts/refresh_cns5_snapshot.py",
    "data:generate": "./.venv/bin/python scripts/generate_nearby_systems.py && prettier --write src/data/nearby-systems.json",
    "data:validate": "./.venv/bin/python scripts/validate_data.py",
    "narrative:validate": "tsx scripts/narrative-cli.ts validate",
    "narrative:generate": "tsx scripts/narrative-cli.ts generate",
    "test:e2e": "xvfb-run -a playwright test",
    "build": "npm run data:validate && npm run narrative:validate && tsc -b && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 4173 --strictPort",
    "validate": "npm run format:check && npm run lint && npm run typecheck && npm run data:validate && npm run test && npm run build"
  },
  "dependencies": {
    "@react-three/drei": "10.7.7",
    "@react-three/fiber": "9.6.1",
    "ajv": "8.17.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "10.7.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "0.5.3",
    "jsdom": "29.1.1",
    "prettier": "3.9.5",
    "tsx": "4.21.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
